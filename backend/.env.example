# Base de datos — copiar desde Railway al crear el proyecto
DATABASE_URL="postgresql://usuario:password@host:5432/cultura_constitucion"

# JWT — generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="reemplazar_por_string_aleatorio_de_64_caracteres_minimo"
JWT_EXPIRES_IN="7d"

# Cloudinary — obtener desde cloudinary.com/console
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"

# Puerto local del backend
PORT=3001

# URL del frontend (para CORS)
FRONTEND_URL="http://localhost:5173"
